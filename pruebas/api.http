# ========================================
# CATÁLOGO DE PRODUCTOS
# ========================================

### GET - Listar productos
GET {{host}}/api/catalogo-productos?page=1&pageSize=20

### GET - Filtrar por categoría
GET {{host}}/api/catalogo-productos?categoria=electronica

### GET - Filtrar por mayorista
GET {{host}}/api/catalogo-productos?id_mayorista=00000000-0000-0000-0000-000000000000

### GET - Filtrar por categoría y mayorista
GET {{host}}/api/catalogo-productos?categoria=electronica&id_mayorista=00000000-0000-0000-0000-000000000000

### GET - Buscar productos
GET {{host}}/api/catalogo-productos?search=celular

### GET - Obtener producto por ID
GET {{host}}/api/catalogo-productos/00000000-0000-0000-0000-000000000000

### POST - Crear producto
POST {{host}}/api/catalogo-productos
Content-Type: application/json

{
  "id_mayorista": "00000000-0000-0000-0000-000000000000",
  "nombre_articulo": "Producto Test",
  "categoria": "electronica",
  "precio_mayorista": 100.00,
  "precio_dwlabs": 150.00,
  "materiales": "plastico",
  "moq": 10
}

# Error validación:
# {
#   "success": false,
#   "error": "ValidationError",
#   "message": "El nombre del articulo es requerido"
# }

### PUT - Actualizar producto completo
PUT {{host}}/api/catalogo-productos/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "nombre_articulo": "Producto Actualizado",
  "categoria": "hogar",
  "precio_mayorista": 120.00,
  "precio_dwlabs": 180.00
}

### PATCH - Actualizar producto parcialmente
PATCH {{host}}/api/catalogo-productos/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "precio_dwlabs": 200.00
}

### DELETE - Eliminar producto
DELETE {{host}}/api/catalogo-productos/00000000-0000-0000-0000-000000000000

---

# ========================================
# SOLICITUDES DE COTIZACIÓN
# ========================================

### GET - Listar solicitudes
GET {{host}}/api/solicitudes-cotizacion?page=1&pageSize=20

### GET - Filtrar por estado
GET {{host}}/api/solicitudes-cotizacion?estado=pendiente

### GET - Filtrar por nivel de urgencia
GET {{host}}/api/solicitudes-cotizacion?nivel_urgencia=alta

### GET - Filtrar por cliente
GET {{host}}/api/solicitudes-cotizacion?id_cliente=00000000-0000-0000-0000-000000000000

### GET - Buscar solicitudes
GET {{host}}/api/solicitudes-cotizacion?search=celular

### GET - Obtener solicitud por ID
GET {{host}}/api/solicitudes-cotizacion/00000000-0000-0000-0000-000000000000

### POST - Crear solicitud
POST {{host}}/api/solicitudes-cotizacion
Content-Type: application/json

{
  "id_cliente": "00000000-0000-0000-0000-000000000000",
  "descripcion_articulo": "Celular Samsung Galaxy",
  "especificaciones_requeridas": {"color": "negro", "ram": "8gb"},
  "nivel_urgencia": "alta",
  "estado_solicitud": "pendiente"
}

### PUT - Actualizar solicitud completa
PUT {{host}}/api/solicitudes-cotizacion/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "descripcion_articulo": "Celular actualizado",
  "nivel_urgencia": "normal",
  "estado_solicitud": "procesando"
}

### PATCH - Actualizar parcialmente
PATCH {{host}}/api/solicitudes-cotizacion/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "estado_solicitud": "aprobada"
}

### DELETE - Eliminar solicitud
DELETE {{host}}/api/solicitudes-cotizacion/00000000-0000-0000-0000-000000000000

---

