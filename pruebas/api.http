@host = http://localhost:5145

# ==============================================================================
# DownLabs.Core.Api - Pruebas API
# ==============================================================================
# Credenciales: mayorista1@downlabs.com / Test1234!
# ==============================================================================

# ==============================================================================
# AUTH
# ==============================================================================

### POST /api/auth/register - Crear usuario
### REQUIRED: email, password, rol
### rol: "cliente" | "mayorista" | "operador"
### Para clientes/mayoristas agregar: nombre_empresa
### Para operadores agregar: nombre, apellido
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "email": "nuevo@downlabs.com",
  "password": "Test1234!",
  "rol": "cliente",
  "nombre_empresa": "Empresa Test"
}

### POST /api/auth/login - Iniciar sesión
### REQUIRED: email, password
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "mayorista1@downlabs.com",
  "password": "Test1234!"
}

# ==============================================================================
# CLIENTES
# ==============================================================================

### GET /api/clientes - Listar todos
GET {{host}}/api/clientes

### GET /api/clientes/{id} - Obtener por ID
GET {{host}}/api/clientes/9d0d95ab-8dfa-402b-9e3d-5f1af713a0c7

### POST /api/clientes - Crear cliente
### REQUIRED: nombre_empresa
### Campos adicionales: direccion_fiscal (era codigo_postal_fiscal)
POST {{host}}/api/clientes
Content-Type: application/json

{
  "nombre_empresa": "Nueva Empresa",
  "correo_contacto": "email@empresa.com",
  "direccion_fiscal": "Calle Principal 123, Ciudad, Mexico"
}

### PATCH /api/clientes/{id} - Actualizar parcialmente
PATCH {{host}}/api/clientes/9d0d95ab-8dfa-402b-9e3d-5f1af713a0c7
Content-Type: application/json

{
  "telefono_contacto": "5551234567",
  "direccion_fiscal": "Nueva Direccion 456"
}
}

# ==============================================================================
# MAYORISTAS
# ==============================================================================

### GET /api/mayoristas - Listar todos
GET {{host}}/api/mayoristas

### GET /api/mayoristas/{id} - Obtener por ID
GET {{host}}/api/mayoristas/e6c956e3-d4ff-4da6-add4-09c9eae3e3e3

### POST /api/mayoristas - Crear mayorista
### REQUIRED: nombre_empresa
### Campos adicionales: rfc, nombre_operador
POST {{host}}/api/mayoristas
Content-Type: application/json

{
  "nombre_empresa": "Nueva Distribuidora",
  "rfc": "XAXX010101AB",
  "nombre_operador": "Juan Perez"
}

### PATCH /api/mayoristas/{id} - Actualizar parcialmente
PATCH {{host}}/api/mayoristas/e6c956e3-d4ff-4da6-add4-09c9eae3e3e3
Content-Type: application/json

{
  "nivel_confianza": 8,
  "rfc": "XBXX020202CD",
  "nombre_operador": "Maria Garcia"
}

# ==============================================================================
# OPERADORES
# ==============================================================================

### GET /api/operadores - Listar todos
GET {{host}}/api/operadores

### GET /api/operadores/{id} - Obtener por ID
GET {{host}}/api/operadores/4039428b-2928-4652-8e63-5ad1678859c5

### POST /api/operadores - Crear operador
### REQUIRED: nombre, apellido, email
POST {{host}}/api/operadores
Content-Type: application/json

{
  "nombre": "Juan",
  "apellido": "Perez",
  "email": "juan@downlabs.com"
}

### PATCH /api/operadores/{id} - Actualizar parcialmente
PATCH {{host}}/api/operadores/4039428b-2928-4652-8e63-5ad1678859c5
Content-Type: application/json

{
  "activo": false
}

# ==============================================================================
# CATÁLOGO DE PRODUCTOS
# ==============================================================================

### GET /api/catalogo-productos - Listar todos
GET {{host}}/api/catalogo-productos

### GET /api/catalogo-productos/{id} - Obtener por ID
GET {{host}}/api/catalogo-productos/b52199c5-95b2-4935-86c9-af92ce8d1042

### POST /api/catalogo-productos - Crear producto
### REQUIRED: id_mayorista (UUID de mayoristas)
POST {{host}}/api/catalogo-productos
Content-Type: application/json

{
  "id_mayorista": "e6c956e3-d4ff-4da6-add4-09c9eae3e3e3",
  "nombre_articulo": "Nuevo Producto",
  "categoria": "Electronica"
}

### PATCH /api/catalogo-productos/{id} - Actualizar parcialmente
PATCH {{host}}/api/catalogo-productos/b52199c5-95b2-4935-86c9-af92ce8d1042
Content-Type: application/json

{
  "precio_dwlabs": 150.00
}

# ==============================================================================
# SOLICITUDES DE COTIZACIÓN
# ==============================================================================

### GET /api/solicitudes-cotizacion - Listar todas
GET {{host}}/api/solicitudes-cotizacion

### GET /api/solicitudes-cotizacion/{id} - Obtener por ID
GET {{host}}/api/solicitudes-cotizacion/dbeeb242-fa25-4493-be14-bf270e78f1d6

### POST /api/solicitudes-cotizacion - Crear solicitud
### REQUIRED: id_cliente (UUID de clientes)
### estado_solicitud: "Pendiente" | "Cotizada" | "Rechazada"
### nivel_urgencia: "Normal" | "Urgente"
POST {{host}}/api/solicitudes-cotizacion
Content-Type: application/json

{
  "id_cliente": "9d0d95ab-8dfa-402b-9e3d-5f1af713a0c7",
  "descripcion_articulo": "Nuevo articulo",
  "estado_solicitud": "Pendiente"
}

### PATCH /api/solicitudes-cotizacion/{id} - Actualizar parcialmente
PATCH {{host}}/api/solicitudes-cotizacion/dbeeb242-fa25-4493-be14-bf270e78f1d6
Content-Type: application/json

{
  "estado_solicitud": "Cotizada"
}

# ==============================================================================
# COTIZACIONES
# ==============================================================================

### GET /api/cotizaciones - Listar todas
GET {{host}}/api/cotizaciones

### GET /api/cotizaciones/{id} - Obtener por ID
GET {{host}}/api/cotizaciones/9515202d-99f6-4183-8128-e3a1da3ecaac

### POST /api/cotizaciones - Crear cotización
### REQUIRED: id_solicitud, id_producto, id_operador (UUIDs)
### estado: "Negociando" | "Aceptada" | "Rechazada"
POST {{host}}/api/cotizaciones
Content-Type: application/json

{
  "id_solicitud": "dbeeb242-fa25-4493-be14-bf270e78f1d6",
  "id_producto": "b52199c5-95b2-4935-86c9-af92ce8d1042",
  "id_operador": "4039428b-2928-4652-8e63-5ad1678859c5",
  "estado": "Negociando"
}

### PATCH /api/cotizaciones/{id} - Actualizar parcialmente
PATCH {{host}}/api/cotizaciones/9515202d-99f6-4183-8128-e3a1da3ecaac
Content-Type: application/json

{
  "estado": "Aceptada"
}

# ==============================================================================
# PEDIDOS DE CRÉDITO
# ==============================================================================

### GET /api/pedidos-credito - Listar todos
GET {{host}}/api/pedidos-credito

### GET /api/pedidos-credito/{id} - Obtener por ID
GET {{host}}/api/pedidos-credito/35867852-fdba-4653-8a8b-7fa0538cf020

### POST /api/pedidos-credito - Crear pedido
### REQUIRED: id_cotizacion (UUID de cotizaciones)
### estado_pago: "Pendiente" | "Pagado" | "En mora"
### tipo_pago: "credito" | "contado"
POST {{host}}/api/pedidos-credito
Content-Type: application/json

{
  "id_cotizacion": "e82d49e0-5be0-447b-a01d-57484bc7d4b9",
  "estado_pago": "Pendiente"
}

### PATCH /api/pedidos-credito/{id} - Actualizar parcialmente
PATCH {{host}}/api/pedidos-credito/35867852-fdba-4653-8a8b-7fa0538cf020
Content-Type: application/json

{
  "estado_pago": "Pagado"
}