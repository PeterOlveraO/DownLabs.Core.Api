# ========================================
# OPERADORES
# ========================================

### GET - Listar operadores
GET {{host}}/api/operadores?page=1&pageSize=20

### GET - Filtrar por rol
GET {{host}}/api/operadores?rol=admin

### GET - Buscar operadores
GET {{host}}/api/operadores?search=admin

### GET - Obtener operador por ID
GET {{host}}/api/operadores/00000000-0000-0000-0000-000000000000

### POST - Crear operador
POST {{host}}/api/operadores
Content-Type: application/json

{
  "nombre": "Operador Test",
  "correo": "operador@test.com",
  "contrasena": "password123",
  "rol": "admin"
}

# Error validación:
# {
#   "success": false,
#   "error": "ValidationError",
#   "message": "El nombre es requerido"
# }

### PUT - Actualizar operador completo
PUT {{host}}/api/operadores/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "nombre": "Operador Actualizado",
  "correo": "actualizado@test.com",
  "rol": "editor"
}

### PATCH - Actualizar operador parcialmente
PATCH {{host}}/api/operadores/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "rol": "admin"
}

### DELETE - Eliminar operador
DELETE {{host}}/api/operadores/00000000-0000-0000-0000-000000000000

