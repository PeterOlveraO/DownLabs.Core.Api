@host = http://localhost:5145

# ========================================
# HEALTH CHECK
# ========================================

### Health Check
# Verifica que el servidor esté funcionando
GET {{host}}/api/health

# Respuesta esperada:
# {
#   "status": "OK",
#   "timestamp": "2026-04-17T12:00:00Z"
# }

---

# ========================================
# CLIENTES
# ========================================

### GET - Listar clientes (paginación básica)
# Obtiene todos los clientes con paginación
GET {{host}}/api/clientes?page=1&pageSize=5

# Respuesta exitosa:
# {
#   "success": true,
#   "data": [...],
#   "pagination": {
#     "page": 1,
#     "pageSize": 5,
#     "total": 10,
#     "totalPages": 2,
#     "hasNext": true,
#     "hasPrev": false
#   }
# }

### GET - Buscar clientes por nombre o correo
GET {{host}}/api/clientes?search=empresa&page=1&pageSize=20

### GET - Obtener cliente por ID
GET {{host}}/api/clientes/00000000-0000-0000-0000-000000000000

# Error not found (404):
# {
#   "success": false,
#   "error": "NotFound",
#   "message": "Cliente no encontrado"
# }

### POST - Crear nuevo cliente
POST {{host}}/api/clientes
Content-Type: application/json

{
  "nombre_empresa": "Empresa Test",
  "correo_contacto": "test@email.com",
  "telefono_contacto": "1234567890",
  "rfc": "XAXX010101000",
  "codigo_postal_fiscal": "01200"
}

# Error validación (400):
# {
#   "success": false,
#   "error": "ValidationError",
#   "message": "El nombre de la empresa es requerido"
# }

### PUT - Actualizar cliente completo
PUT {{host}}/api/clientes/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "nombre_empresa": "Empresa Actualizada",
  "correo_contacto": "actualizado@email.com",
  "telefono_contacto": "9876543210",
  "rfc": "XAXX010101001",
  "codigo_postal_fiscal": "01201"
}

### PATCH - Actualizar cliente parcialmente
PATCH {{host}}/api/clientes/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "telefono_contacto": "9876543210"
}

### DELETE - Eliminar cliente
DELETE {{host}}/api/clientes/00000000-0000-0000-0000-000000000000

# Respuesta exitosa:
# {
#   "success": true,
#   "message": "Cliente eliminado correctamente"
# }

---

# ========================================
# MAYORISTAS
# ========================================

### GET - Listar mayoristas
GET {{host}}/api/mayoristas?page=1&pageSize=20

### GET - Buscar mayoristas
GET {{host}}/api/mayoristas?search= Distribuidora

### GET - Obtener mayorista por ID
GET {{host}}/api/mayoristas/00000000-0000-0000-0000-000000000000

### POST - Crear mayorista
POST {{host}}/api/mayoristas
Content-Type: application/json

{
  "nombre_empresa": "Mayorista Test",
  "ubicacion": "CDMX",
  "correo_contacto": "mayorista@test.com",
  "telefono_contacto": "1234567890",
  "nivel_confianza": 5
}

### PUT - Actualizar mayorista completo
PUT {{host}}/api/mayoristas/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "nombre_empresa": "Mayorista Actualizado",
  "ubicacion": "Guadalajara",
  "correo_contacto": "nuevo@test.com"
}

### PATCH - Actualizar mayorista parcialmente
PATCH {{host}}/api/mayoristas/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "nivel_confianza": 8
}

### DELETE - Eliminar mayorista
DELETE {{host}}/api/mayoristas/00000000-0000-0000-0000-000000000000

