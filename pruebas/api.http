# ========================================
# PEDIDOS DE CRÉDITO
# ========================================

### GET - Listar pedidos
GET {{host}}/api/pedidos-credito?page=1&pageSize=20

### GET - Filtrar por estado de pago
GET {{host}}/api/pedidos-credito?estado_pago=pendiente

### GET - Filtrar por requiere crédito
GET {{host}}/api/pedidos-credito?requiere_credito=true

### GET - Filtrar por cotización
GET {{host}}/api/pedidos-credito?id_cotizacion=00000000-0000-0000-0000-000000000000

### GET - Obtener pedido por ID
GET {{host}}/api/pedidos-credito/00000000-0000-0000-0000-000000000000

### POST - Crear pedido
POST {{host}}/api/pedidos-credito
Content-Type: application/json

{
  "id_cotizacion": "00000000-0000-0000-0000-000000000000",
  "requiere_credito": true,
  "cargo_financiamiento": 10.50,
  "monto_total_deuda": 250.00,
  "estado_pago": "pendiente",
  "fecha_inicio_credito": "2026-05-01",
  "fecha_vencimiento_credito": "2026-11-01",
  "requiere_factura": true,
  "tipo_pago": "credito"
}

### PUT - Actualizar pedido completo
PUT {{host}}/api/pedidos-credito/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "requiere_credito": true,
  "cargo_financiamiento": 15.00,
  "monto_total_deuda": 300.00,
  "estado_pago": "pagando",
  "tipo_pago": "contado"
}

### PATCH - Actualizar parcialmente
PATCH {{host}}/api/pedidos-credito/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "estado_pago": "completado"
}

### DELETE - Eliminar pedido
DELETE {{host}}/api/pedidos-credito/00000000-0000-0000-0000-000000000000

---

# ========================================
# PRUEBAS DE ERROR
# ========================================

### GET recurso no existente (404)
GET {{host}}/api/clientes/99999999-9999-9999-9999-999999999999

# Respuesta:
# {
#   "success": false,
#   "error": "NotFound",
#   "message": "Cliente no encontrado"
# }

### POST sin campos requeridos (400)
POST {{host}}/api/clientes
Content-Type: application/json

{}

# Respuesta:
# {
#   "success": false,
#   "error": "ValidationError",
#   "message": "El nombre de la empresa es requerido"
# }

### DELETE recurso no existente (404)
DELETE {{host}}/api/clientes/99999999-9999-9999-9999-999999999999

# Respuesta:
# {
#   "success": false,
#   "error": "NotFound",
#   "message": "Cliente no encontrado"
# }